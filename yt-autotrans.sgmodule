#!name=🗝️ YT AutoTrans Error
#!desc=修复 YouTube iOS 自动翻译字幕 429，并在失败时显示诊断原因 / Fix YouTube iOS auto-translate 429 with visible diagnostics.
#!system=ios
#!icon=https://raw.githubusercontent.com/CyberDoctor2023/yt-autotrans/main/assets/icon.svg
#!version=2026.05.02.3
#!arguments=mode:dual,provider:google,debug:translate,version:v2026.05.02.3
#!arguments-desc=[版本 / Version]\n\nversion=v2026.05.02.3：普通用户正式版；翻译失败时不仅 header 标记原因，也把 Google Sorry、重定向、超时、解析失败等具体原因同步显示到字幕里；provider 目前仅支持 google；脚本不会读取 version 参数 / Stable release for regular users. Shows the concrete failure reason in subtitles as well as headers: Google Sorry, redirect, timeout, parse failure, and more. provider currently supports google only. Scripts do not read the version parameter.\n\n[模式 / Mode]\n\nmode=dual：双语，原文在上，译文在下；英译中时就是英中 / Source above translation.\n\nmode=reverse：双语，译文在上，原文在下；英译中时就是中英 / Translation above source.\n\nmode=single：单语，只显示译文 / Translation only.\n\n[翻译接口 / Provider]\n\nprovider=google：默认，使用 translate.googleapis.com gtx / Default Google gtx endpoint.\n\n[调试 / Debug]\n\ndebug=translate：默认，只在有 tlang/meta 但翻译全失败时覆盖所有字幕为调试信息 / Default. Show all-cue diagnostics only when translation fully fails after confirmed tlang/meta.\n\ndebug=all：同时对 no-meta 覆盖所有字幕，用于排查 302/meta 链路；会影响普通英文字幕 / Also diagnose no-meta; affects ordinary English captions.\n\ndebug=off：关闭调试字幕，失败时只写 header 并返回原字幕 / Disable diagnostic subtitles.

[Script]
youtube-timedtext-request = type=http-request,pattern=^https:\/\/www\.youtube\.com\/api\/timedtext\?.*tlang=,timeout=5,script-update-interval=3600,script-path=https://raw.githubusercontent.com/CyberDoctor2023/yt-autotrans/main/yt_autotrans_request.js?v=2026.05.02.3
youtube-timedtext-response = type=http-response,pattern=^https:\/\/www\.youtube\.com\/api\/timedtext,requires-body=true,max-size=10485760,timeout=60,script-update-interval=3600,argument=mode={{{mode}}}&provider={{{provider}}}&debug={{{debug}}},script-path=https://raw.githubusercontent.com/CyberDoctor2023/yt-autotrans/main/yt_autotrans_response.js?v=2026.05.02.3

[MITM]
hostname = %APPEND% www.youtube.com
