#!name=🧪 YT AutoTrans Error Beta 1
#!desc=测试版 1：12 并发翻译 / Beta 1: 12 parallel translation chunks.
#!system=ios
#!icon=https://raw.githubusercontent.com/CyberDoctor2023/yt-autotrans/main/assets/icon.svg
#!version=2026.05.01.10-beta.1
#!arguments=mode:dual,version:v2026.05.01.10-beta.1
#!arguments-desc=[测试版版本 / Beta Version]\n\nversion=v2026.05.01.10-beta.1：用于和 beta1 分支对照；脚本不会读取这个参数 / For checking against the beta1 branch. Scripts do not read this parameter.\n\n[模式 / Mode]\n\nmode=dual：双语，原文在上，译文在下；英译中时就是英中 / Source above translation.\n\nmode=reverse：双语，译文在上，原文在下；英译中时就是中英 / Translation above source.\n\nmode=single：单语，只显示译文 / Translation only.

[Script]
youtube-timedtext-request = type=http-request,pattern=^https:\/\/www\.youtube\.com\/api\/timedtext\?.*tlang=,timeout=5,script-update-interval=600,script-path=https://raw.githubusercontent.com/CyberDoctor2023/yt-autotrans/beta1/yt_autotrans_request.js?v=2026.05.01.10-beta.1
youtube-timedtext-response = type=http-response,pattern=^https:\/\/www\.youtube\.com\/api\/timedtext\?,requires-body=true,max-size=2097152,timeout=60,script-update-interval=600,argument=mode={{{mode}}},script-path=https://raw.githubusercontent.com/CyberDoctor2023/yt-autotrans/beta1/yt_autotrans_response.js?v=2026.05.01.10-beta.1

[MITM]
hostname = %APPEND% www.youtube.com
